DEEPSEEK_API_KEY=sk-xxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Maker-Checker 异构模型（留空则均使用 DEEPSEEK_MODEL）
WRITER_MODEL=deepseek-chat
QA_MODEL=deepseek-reasoner
# 对带 Schema 的 JSON 调用尝试 json_schema strict（不支持时自动降级）
LLM_USE_JSON_SCHEMA=1
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

DB_PATH=./tbe.db
KNOWLEDGE_ROOT=./knowledge
OUTPUT_DIR=./output
UPLOAD_DIR=./uploads

BM25_TOP_K=5
EMBEDDING_MODEL_PATH=./models/bge-small-zh-v1.5
EMBEDDING_ENABLED=1
RETRIEVAL_RRF_K=60
MIN_DIGIT_RATIO=0.5
MAX_QA_RETRY=2

API_PORT=3333
# 章节标题多级编号：none | decimal | chapter_cn | outline_mixed
HEADING_NUMBERING_PRESET=decimal
# 跨域白名单（逗号分隔）。留空则自动使用 http://localhost:{API_PORT} 与 http://127.0.0.1:{API_PORT}
# CORS_ORIGINS=http://localhost:3333,http://127.0.0.1:3333
